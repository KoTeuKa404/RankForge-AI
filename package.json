{
  "name": "rankforge-ai",
  "version": "1.0.0-rc.1",
  "private": true,
  "description": "AI-driven technical SEO and SearchOps command center for ChatGPT Sites and Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "npm run build && concurrently -k -n web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:fast": "concurrently -k -n web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:api": "wrangler dev --port 8787",
    "build:web": "vite build",
    "build:migrations": "node scripts/prepare-sites-migrations.mjs",
    "build:server": "node scripts/build-sites-worker.mjs",
    "build": "tsc --noEmit && npm run build:migrations && npm run build:web && npm run build:server",
    "test": "vitest run",
    "release:check": "node scripts/release-check.mjs",
    "smoke": "node scripts/smoke.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=high",
    "check": "npm run build && npm run test && npm run release:check && npm run audit:prod",
    "release:verify": "npm run check && npm run smoke",
    "db:migrate:local": "wrangler d1 migrations apply rankforge-ai --local",
    "db:migrate:remote": "wrangler d1 migrations apply rankforge-ai --remote",
    "deploy:cloudflare": "npm run check && wrangler deploy"
  },
  "keywords": [
    "seo",
    "searchops",
    "search-console",
    "audit",
    "ai",
    "chatgpt-sites",
    "cloudflare-workers",
    "d1",
    "r2",
    "typescript"
  ],
  "author": "KoTeuKa404",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "node-html-parser": "^9.0.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260721.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
