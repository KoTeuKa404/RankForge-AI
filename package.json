{
  "name": "rankforge-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-driven technical SEO audit",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:api": "wrangler dev --port 8787",
    "build": "tsc --noEmit && vite build",
    "check": "npm run build && npm run test && npm audit --audit-level=high",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply rankforge-ai --local",
    "db:migrate:remote": "wrangler d1 migrations apply rankforge-ai --remote",
    "deploy:cloudflare": "npm run build && wrangler deploy"
  },
  "keywords": [
    "seo",
    "audit",
    "ai",
    "chatgpt-sites",
    "d1",
    "typescript"
  ],
  "author": "KoTeuKa404",
  "license": "MIT",
  "dependencies": {
    "node-html-parser": "^9.0.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260721.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
