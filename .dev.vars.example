# Copy this file to .dev.vars for local development only.
# Never commit .dev.vars.

# AI Fix is optional. Select auto, openai, or gemini.
# auto prefers OpenAI when both keys exist and falls back to Gemini if OpenAI fails.
AI_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Use at least 32 random characters before testing the protected scheduler endpoint.
MONITOR_TOKEN=replace_with_at_least_32_random_characters

# Local-only identity. The server accepts this only for localhost/127.0.0.1
# while ENVIRONMENT=development.
DEV_USER_EMAIL=developer@localhost
ENVIRONMENT=development
